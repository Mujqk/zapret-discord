import { Button, ComboBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Zapret by Sayurin (Slint Edition)";
    no-frame: true;
    
    // Динамические параметры темы из C++ Theme.h
    in property <color> color-bg: #0f0f13;
    in property <color> color-card-bg: #15151c;
    in property <color> color-text: #f5f6f8;
    in property <color> color-text-disabled: #707080;
    in property <color> color-accent: #7b66f2;
    in property <color> color-accent-hover: #8c7bf5;
    in property <color> color-border: #252530;
    
    in property <color> color-status-connected: #4df56e;
    in property <color> color-status-searching: #ffd44b;
    in property <color> color-status-disconnected: #ff5b5b;

    in property <int> window-width: 780;
    in property <int> window-height: 780;
    
    background: color-bg;
    width: window-width * 1px;
    height: window-height * 1px;

    // Свойства состояния
    in property <string> status-text: "Отключено";
    in property <string> version-text: "1.0.0";
    in property <[string]> available-alts: [];
    in-out property <int> current-alt-idx: 0;
    in property <[string]> log-lines: [];
    in property <bool> is-connected: false;
    in property <bool> is-searching: false;

    // Сигналы обратного вызова (Callbacks)
    callback start-clicked();
    callback stop-clicked();
    callback auto-search-clicked();
    callback start-service-clicked();
    callback next-alt-clicked();
    callback open-files-clicked();
    callback link-clicked(string);
    callback close-clicked();
    callback minimize-clicked();

    // Главный контейнер разметки
    VerticalLayout {
        padding-left: 30px;
        padding-right: 30px;
        padding-top: 15px;
        padding-bottom: 20px;
        spacing: 20px;

        // Панель заголовка окна
        HorizontalLayout {
            height: 45px;
            alignment: space-between;

            // Блок логотипа

            HorizontalLayout {
                spacing: 12px;
                alignment: start;
                Text {
                    text: "ZAPRET";
                    font-size: 26px;
                    font-weight: 800;
                    color: color-text;
                    vertical-alignment: center;
                }
                Text {
                    text: "|  v" + version-text + " Stable";
                    font-size: 14px;
                    color: color-text-disabled;
                    vertical-alignment: center;
                }
            }

            // Управление окном
            HorizontalLayout {
                spacing: 10px;
                alignment: end;
                
                // Кнопка свертывания
                Rectangle {
                    width: 32px;
                    height: 32px;
                    background: min-touch.has-hover ? color-card-bg : transparent;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: color-border;
                    
                    Text {
                        text: "—";
                        color: min-touch.has-hover ? color-accent : color-text;
                        font-size: 14px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    min-touch := TouchArea {
                        clicked => { root.minimize-clicked(); }
                    }
                }

                // Кнопка закрытия
                Rectangle {
                    width: 32px;
                    height: 32px;
                    background: close-touch.has-hover ? color-card-bg : transparent;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: color-border;

                    Text {
                        text: "✕";
                        color: close-touch.has-hover ? color-status-disconnected : color-text;
                        font-size: 14px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    close-touch := TouchArea {
                        clicked => { root.close-clicked(); }
                    }
                }
            }
        }

        // Карточка статуса
        Rectangle {
            height: 100px;
            background: color-card-bg;
            border-radius: 12px;
            border-width: 1px;
            border-color: color-border;

            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                alignment: space-between;
                
                VerticalLayout {
                    alignment: center;
                    spacing: 4px;
                    Text {
                        text: "ТЕКУЩИЙ СТАТУС ОБХОДА";
                        font-size: 12px;
                        font-weight: 700;
                        color: color-text-disabled;
                    }
                    Text {
                        text: status-text;
                        font-size: 28px;
                        font-weight: 800;
                        color: is-connected ? color-status-connected : (is-searching ? color-status-searching : color-status-disconnected);
                    }
                }

                // Индикатор состояния (LED)
                Rectangle {
                    width: 44px;
                    height: 44px;
                    
                    Rectangle {
                        width: 16px;
                        height: 16px;
                        border-radius: 8px;
                        background: is-connected ? color-status-connected : (is-searching ? color-status-searching : color-status-disconnected);
                    }
                }
            }
        }

        // Панель управления
        Rectangle {
            height: 250px;
            background: color-card-bg;
            border-radius: 12px;
            border-width: 1px;
            border-color: color-border;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                alignment: space-between;

                // Метка секции
                Text {
                    text: "НАСТРОЙКИ ОБХОДА";
                    font-size: 12px;
                    font-weight: 700;
                    color: color-text-disabled;
                }

                // Выпадающий список выбора стратегии
                ComboBox {
                    model: available-alts;
                    current-index: current-alt-idx;
                    enabled: !is-connected && !is-searching;
                }

                // Кнопки действия (Ряд 1)
                HorizontalLayout {
                    spacing: 12px;
                    height: 48px;

                    // Главная кнопка Запустить/Остановить
                    Button {
                        text: is-connected ? "ОСТАНОВИТЬ" : "ЗАПУСТИТЬ";
                        enabled: !is-searching;
                        
                        clicked => {
                            if (is-connected) {
                                root.stop-clicked();
                            } else {
                                root.start-clicked();
                            }
                        }
                    }

                    // Кнопка автоподбора стратегии
                    Button {
                        text: is-searching ? "ПОИСК..." : "АВТО-ПОИСК";
                        enabled: !is-connected && !is-searching;
                        clicked => { root.auto-search-clicked(); }
                    }
                }

                // Кнопки действия (Ряд 2)
                HorizontalLayout {
                    spacing: 12px;
                    height: 40px;

                    Button {
                        text: "ЗАПУСК СЛУЖБЫ";
                        enabled: !is-connected && !is-searching;
                        clicked => { root.start-service-clicked(); }
                    }

                    Button {
                        text: "СЛЕДУЮЩИЙ ALT";
                        enabled: !is-connected && !is-searching && available-alts.length > 0;
                        clicked => { root.next-alt-clicked(); }
                    }
                }
            }
        }

        // Секция журнала событий
        VerticalLayout {
            spacing: 8px;
            Text {
                text: "ЖУРНАЛ СОБЫТИЙ";
                font-size: 12px;
                font-weight: 700;
                color: color-text-disabled;
            }

            Rectangle {
                background: #09090b;
                border-radius: 8px;
                border-width: 1px;
                border-color: color-border;
                height: 180px;

                ScrollView {
                    padding: 12px;

                    VerticalLayout {
                        alignment: start;
                        spacing: 6px;
                        
                        for log in log-lines : HorizontalLayout {
                            alignment: start;
                            spacing: 8px;
                            
                            Text {
                                text: ">";
                                color: color-accent;
                                font-weight: 700;
                            }
                            
                            Text {
                                text: log;
                                color: color-text;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }

        // Подвал окна
        HorizontalLayout {
            alignment: space-between;
            height: 36px;


            // Links / References
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                
                Text {
                    text: "GitHub: Flowseal/zapret-discord-youtube";
                    font-size: 11px;
                    color: color-accent;
                    
                    TouchArea {
                        clicked => { root.link-clicked("https://github.com/Flowseal/zapret-discord-youtube"); }
                    }
                }
                Text {
                    text: "GitHub: Mujqk/zapret-discord-youtube";
                    font-size: 11px;
                    color: color-accent;
                    
                    TouchArea {
                        clicked => { root.link-clicked("https://github.com/Mujqk/zapret-discord-youtube"); }
                    }
                }
            }

            // Кнопки управления файлами и службой
            HorizontalLayout {
                spacing: 10px;

                Button {
                    text: "СЛУЖБА";
                    width: 110px;
                    height: 32px;
                    clicked => { root.start-service-clicked(); }
                }

                Button {
                    text: "ОТКРЫТЬ ФАЙЛЫ";
                    width: 145px;
                    height: 32px;
                    clicked => { root.open-files-clicked(); }
                }
            }
        }
    }
}

